# BEGIN Addmoments
<IfModule mod_rewrite.c>
RewriteEngine On

# 1. UI → S3 proxy (fire first, before trailing slash check)
RewriteRule ^(ui)(?:/(.*))?$ https://memboxpub-qo1gff2e.s3.eu-north-1.amazonaws.com/$1/$2 [R=307,L,QSA]

# 2. Auth/API → Backend proxy
RewriteRule ^(auth|api|l)(?:/(.*))?$ https://serv.addmoments.com.ua/$1/$2 [R=307,L,QSA]

# 3. React SPA fallback (internal rewrite, no redirect)
RewriteCond %{QUERY_STRING} !(^|&)rnf=1(&|$)
RewriteRule ^(event|events|guest|checkout|payment|signin|recover|notice|signup|signout|reset-password)(?:/(.*))?$ /reactApp.html [L]

# 4. Trailing slash redirect (fire LAST, after all other rules)
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(event|events|guest|checkout|payment|signin|recover|notice|signup|signout|reset-password)
RewriteRule ^(.+)$ /$1/ [R=301,L]

</IfModule>
# END Addmoments